{
  "name": "bloxd-translation-layer",
  "version": "1.2.6",
  "description": "A middle man to translate Bloxd packets into Minecraft 1.8.9 packets.",
  "main": "dist-main/index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node scripts/dev-electron.js",
    "build": "vite build",
    "package": "electron-builder --config electron-builder.config.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "node --check index.js && node --check server.js && node --check bloxd/types/browser_info.js && node --check bloxd/matchmake.js",
    "postinstall": "node scripts/patch-schema.js"
  },
  "author": "7GrandDad",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@colyseus/schema": "^3.0.76",
    "@fluentui/react-components": "^9.74.3",
    "@fluentui/react-icons": "^2.0.316",
    "@vitejs/plugin-react": "^6.0.3",
    "avsc": "^5.7.7",
    "colyseus.js": "^0.16.22",
    "minecraft-data": "3.85.0",
    "minecraft-protocol": "^1.58.0",
    "ndarray": "^1.0.19",
    "pako": "^2.1.0",
    "prismarine-chunk": "^1.38.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vec3": "^0.1.10",
    "vite": "^8.1.3",
    "vite-plugin-electron": "^1.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  }
}
